PORT=3000
NODE_ENV=development
# Use a URI do pooler (Session mode) em Dashboard > Database > Connection string.
# Evita ENOTFOUND em redes só IPv4: o host db.<ref>.supabase.co costuma ser só IPv6.
# Formato: postgresql://postgres.[PROJECT_REF]:[SENHA]@aws-0-REGION.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[SUA-SENHA]@aws-0-REGION.pooler.supabase.com:5432/postgres
JWT_SECRET=sua-chave-super-secreta
JWT_EXPIRES_IN=7d

# Opcional: origens permitidas no CORS (separadas por vírgula).
# Produção: defina as URLs do front (ex.: https://seudominio.com).
# Vazio em desenvolvimento = permissivo para testes locais.
# CORS_ORIGINS=http://localhost:3000

# Popular vitrine com exemplos (só se a tabela products estiver vazia):
# npm run seed:products

# postgresql://postgres.zszkhuliofyndnbofywk:Th1ry2de3&Ju39@aws-1-us-east-1.pooler.supabase.com:5432/postgres

